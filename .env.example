# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://tradeplay:tradeplay@localhost:5433/tradeplay"
# "live"     – prices fluctuate over NSE market hours (default)
# "database" – static: always the newest stored candle, no movement
# "mock"     – tiny in-memory fixture set
MARKET_DATA_PROVIDER="live"

# NSE session open/close in IST, "HH:MM" (24h). Defaults: 09:15–15:30.
# NEXT_PUBLIC_ so the client-side market-open badge/refresher see them too;
# they're inlined at build time, so a rebuild is needed after changing them.
NEXT_PUBLIC_MARKET_OPEN="09:15"
NEXT_PUBLIC_MARKET_CLOSE="15:30"

# Generate a strong random value, for example with: openssl rand -base64 32
AUTH_SECRET="4zI+iDyOU8XDgykqcZkFyXQNshy1wB2VMY3q079fwyg="
AUTH_URL="http://localhost:3002"
NEXT_PUBLIC_APP_NAME="TradePlay"

# Optional: enables the AI trading coach (Phase 6). Without it, the app falls back
# to the free rule-based insights and never breaks. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=""
